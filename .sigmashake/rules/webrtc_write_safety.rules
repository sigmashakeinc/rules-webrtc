# webrtc_write_safety.rules
# Technology: webrtc | Capability: write

rule webrtc-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "createDataChannel"
  MESSAGE "Blocked an unsafe pattern in webrtc. Use the recommended best practices for 2025/2026."
}

rule webrtc-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "webkitRTCPeerConnection"
  MESSAGE "You are using an outdated API for webrtc. Please upgrade to the newer API."
}
